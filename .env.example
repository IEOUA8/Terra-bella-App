# ==============================================================================
# Variables de Entorno para la Aplicación y el Sistema de Notificaciones de Terra Bella
# ==============================================================================

# ------------------------------------------------------------------------------
# SUPABASE CONFIGURATION (Requerido para la conexión a la base de datos)
# Encuentra estos valores en tu Dashboard de Supabase:
# Proyecto > Project Settings (icono de engranaje) > API
# ------------------------------------------------------------------------------

# URL de tu proyecto Supabase.
# Ejemplo: https://abcdefghijklmnop.supabase.co
SUPABASE_URL="YOUR_SUPABASE_PROJECT_URL"

# Clave pública 'anon' (Public Key) de tu proyecto Supabase.
# Se utiliza para la interacción cliente-lado con tu base de datos.
SUPABASE_ANON_KEY="YOUR_SUPABASE_ANON_KEY"

# Clave de 'Service Role' de tu proyecto Supabase.
# ¡IMPORTANTE! Esta clave tiene privilegios de administrador y debe mantenerse SEGRETA.
# Utilizada por las Edge Functions para realizar operaciones con permisos elevados.
SUPABASE_SERVICE_ROLE_KEY="YOUR_SUPABASE_SERVICE_ROLE_KEY"

# ------------------------------------------------------------------------------
# SMTP CONFIGURATION (Para el envío de correos electrónicos transaccionales)
# Aunque Supabase no proporciona un SMTP directo, estas variables serían usadas
# si implementas un servicio de email a través de una Edge Function o un backend
# que se conecte a un proveedor SMTP externo (e.g., SendGrid, Mailgun, Resend).
# **Nota:** El sistema actual utiliza Resend API Key o un RPC 'send_email'
# que requeriría su propia configuración. Adapta según tu proveedor de email.
# ------------------------------------------------------------------------------

# Host del servidor SMTP (ej. smtp.sendgrid.net, smtp.mailgun.org, smtp.resend.com)
SMTP_HOST="YOUR_SMTP_HOST"

# Puerto del servidor SMTP (comúnmente 587 para TLS o 465 para SSL)
SMTP_PORT="YOUR_SMTP_PORT"

# Nombre de usuario para autenticarse en el servidor SMTP
SMTP_USER="YOUR_SMTP_USERNAME"

# Contraseña para autenticarse en el servidor SMTP (a menudo una clave API)
SMTP_PASS="YOUR_SMTP_PASSWORD"

# Dirección de correo electrónico desde la cual se enviarán las notificaciones
SMTP_FROM="no-reply@yourdomain.com"

# ------------------------------------------------------------------------------
# CONFIGURACIÓN DE NOTIFICACIONES POR CORREO ELECTRÓNICO
# ------------------------------------------------------------------------------

# Dirección de correo electrónico a la que se enviarán las notificaciones críticas
# (ej. notificaciones de nuevas reservas a la junta directiva o administración).
# La Edge Function 'on-reserva-created' actualmente envía a 'terrabella.juntad@gmail.com'.
# Puedes cambiarla aquí y en la Edge Function si es necesario.
NOTIFICATION_EMAIL_TO="terrabella.juntad@gmail.com"

# ------------------------------------------------------------------------------
# FIREBASE CLOUD MESSAGING (FCM) CONFIGURATION (Para notificaciones push a guardias)
# Encuentra estos valores en tu Proyecto Firebase > Project settings > Service accounts
# Genera una nueva clave privada para obtener el JSON y extraer los valores.
# Estos son utilizados por la Edge Function 'send-push-notification'.
# ------------------------------------------------------------------------------

# Correo electrónico del cliente de la cuenta de servicio de Firebase.
# Ejemplo: firebase-adminsdk-xxxxx@your-project-id.iam.gserviceaccount.com
FCM_CLIENT_EMAIL="YOUR_FIREBASE_CLIENT_EMAIL"

# Clave privada de la cuenta de servicio de Firebase (incluye -----BEGIN PRIVATE KEY----- y -----END PRIVATE KEY-----).
# Asegúrate de que esté en una sola línea sin saltos de línea y con los saltos de línea escapados como \\n si es necesario.
FCM_PRIVATE_KEY="YOUR_FIREBASE_PRIVATE_KEY"

# Clave del servidor de Firebase para enviar notificaciones (API heredada o Web push certificates -> Key pair).
# Puedes encontrarla en Firebase Project settings > Cloud Messaging.
FCM_SERVER_KEY="YOUR_FIREBASE_SERVER_KEY"

# ID de tu proyecto de Firebase.
# Ejemplo: terrabella-app-f38c1
FIREBASE_PROJECT_ID="YOUR_FIREBASE_PROJECT_ID"

# ------------------------------------------------------------------------------
# RESEND API KEY (Si utilizas Resend para el envío de emails, como welcome-email)
# Obtén tu clave API de Resend en su Dashboard.
# ------------------------------------------------------------------------------
RESEND_API_KEY="YOUR_RESEND_API_KEY"