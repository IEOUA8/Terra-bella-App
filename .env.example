# ==============================================================================
# Variables de Entorno - Terra Bella App
# Copia este archivo como .env y completa los valores
# NUNCA subas .env a git
# ==============================================================================

# ------------------------------------------------------------------------------
# SUPABASE (requerido)
# Dashboard → Project Settings → API
# ------------------------------------------------------------------------------
VITE_SUPABASE_URL=https://TU_PROYECTO.supabase.co
VITE_SUPABASE_ANON_KEY=TU_ANON_KEY

# ------------------------------------------------------------------------------
# WEB PUSH / VAPID (requerido para notificaciones push)
# Genera las claves con: npx web-push generate-vapid-keys
#
# VITE_VAPID_PUBLIC_KEY  → va aquí y en Vercel (es pública, va al frontend)
# VAPID_PRIVATE_KEY      → solo en Supabase Secrets (NUNCA en el frontend)
# ------------------------------------------------------------------------------
VITE_VAPID_PUBLIC_KEY=TU_VAPID_PUBLIC_KEY

# ------------------------------------------------------------------------------
# EMAIL (opcional - para notificaciones por correo)
# Configurar en Supabase Secrets si usas Edge Functions de email
# ------------------------------------------------------------------------------
# RESEND_API_KEY=TU_RESEND_API_KEY
# NOTIFICATION_EMAIL_TO=admin@tucondominioapp.com
